NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# RECAPTCHA — site key is public; secret key must NEVER use NEXT_PUBLIC_
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=<SITE_KEY>
RECAPTCHA_SECRET_KEY=<SECRET_KEY>

# NODE MAILER
NODEMAILER_TRANSPORTER_SERVICE=
NODEMAILER_TRANSPORTER_USER=
NODEMAILER_TRANSPORTER_PASS=
NODEMAILER_OPTIONS_FROM=
NODEMAILER_OPTIONS_TO=

# MAPBOX
NEXT_PUBLIC_ACCESS_TOKEN_MAP_BOX=
NEXT_PUBLIC_URL_MAP_BOX=

# OBSERVABILITY
# Set to "true" to activate Sentry + PostHog (disable locally to avoid noise)
NEXT_PUBLIC_OBSERVABILITY_ENABLED=false

# Sentry — get from sentry.io → Settings → Projects → <project> → Client Keys
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Auth token for source-map uploads during CI builds (never needed locally)
SENTRY_AUTH_TOKEN=

# PostHog — get from app.posthog.com → Project Settings → API Keys
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# AI ASSISTANT
# Google Generative AI key for Gemini — get from aistudio.google.com/app/apikeys
GOOGLE_GENERATIVE_AI_KEY=
